    <section id="about" class="py-24 px-5"><div class="max-w-7xl mx-auto grid lg:grid-cols-3 gap-8 items-stretch">
      <div class="lg:col-span-1 reveal"><p class="text-gold font-semibold tracking-widest">ABOUT US</p><h2 class="mt-4 text-4xl md:text-5xl font-serif">專業肉品代理買賣夥伴</h2></div>
